# Repo-root `.env` is the source of truth (loaded via `bun --env-file ../../.env`).
# This file documents which keys the API consumes.

BETTER_AUTH_SECRET=replace-with-random-32-plus-char-secret
BETTER_AUTH_URL=http://localhost:4000
WEB_URL=http://localhost:3000
PORT=4000

# Read indirectly via packages/db:
DB_FILE_NAME=../../local.db
# TURSO_AUTH_TOKEN=<required only when DB_FILE_NAME is a libsql:// remote URL>
