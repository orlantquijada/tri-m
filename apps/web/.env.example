# API URL (required)
VITE_API_URL=http://localhost:3000

# Demo mode preset. When "true", all VITE_FEATURE_* default OFF.
# Unset (or "false") = full app, all features on.
# VITE_DEMO_MODE=true

# Per-feature overrides. Set "true" to force on, "false" to force off.
# Useful for re-enabling one feature inside a demo build.
# VITE_FEATURE_TODAY=
# VITE_FEATURE_VISITS=
# VITE_FEATURE_TIMELINE=
# VITE_FEATURE_INTAKE_WIZARD=
# VITE_FEATURE_QUICK_ACTIONS=
# VITE_FEATURE_MOBILE_BOTTOM_NAV=
# VITE_FEATURE_AUDIT=
# VITE_FEATURE_BLACKLIST=
# VITE_FEATURE_COLLECTION_ROUTES=
# VITE_FEATURE_VOID_PAYMENT=
# VITE_FEATURE_REPORTS=
# VITE_FEATURE_PASSWORD_RESET=
